# acms-langgraph-poc — Environment Variables
# Copy to .env and fill in your values.
# .env is in .gitignore — never commit credentials.

# ── LLM Provider ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database — Three-Node PostgreSQL ─────────────────────────────────────────
# Tailscale hostnames — never IP addresses
ACES_PRIMARY_HOST=thebeast.tail1234.ts.net
ACES_REPLICA_1_HOST=thebeast.tail1234.ts.net
ACES_REPLICA_2_HOST=minibeast.tail1234.ts.net

ACES_DB_PRIMARY_PASSWORD=your_primary_password
ACES_DB_REPLICA_1_PASSWORD=your_replica_1_password
ACES_DB_REPLICA_2_PASSWORD=your_replica_2_password

# Convenience DSN for LangGraph checkpointer + asyncpg direct use
ACES_DATABASE_URL=postgresql://acms:password@localhost:5432/acms_registry

# ── Search (optional — POC runs without it) ───────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── LangSmith Tracing (optional) ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=acms-langgraph-poc
